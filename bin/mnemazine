#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

ROOT="${MNEMAZINE_ROOT:-$(cd -P "$(dirname "$SOURCE")/.." && pwd)}"
cd "$ROOT"
exec npm start -- "$@"
